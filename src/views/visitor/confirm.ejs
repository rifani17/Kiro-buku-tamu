<%- include('../partials/header', { title: 'Konfirmasi Kunjungan' }) %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <% if (visit) { %>

        <!-- Pesan Sukses -->
        <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
            class="bi bi-check-circle-fill flex-shrink-0 me-2" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
          </svg>
          <div>
            <strong>Pendaftaran berhasil!</strong> Data kunjungan Anda telah tercatat.
          </div>
        </div>

        <!-- Ringkasan Data Kunjungan -->
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-primary text-white">
            <h2 class="h5 mb-0">Ringkasan Kunjungan</h2>
          </div>
          <div class="card-body p-4">
            <dl class="row mb-0">

              <dt class="col-sm-5 text-muted">Nama Lengkap</dt>
              <dd class="col-sm-7"><%= visit.visitor_name %></dd>

              <dt class="col-sm-5 text-muted">Instansi / Asal</dt>
              <dd class="col-sm-7"><%= visit.institution %></dd>

              <dt class="col-sm-5 text-muted">Keperluan</dt>
              <dd class="col-sm-7"><%= visit.purpose %></dd>

              <dt class="col-sm-5 text-muted">Tujuan Kunjungan</dt>
              <dd class="col-sm-7"><%= visit.employee_name %></dd>

              <dt class="col-sm-5 text-muted">Waktu Masuk</dt>
              <dd class="col-sm-7">
                <%= new Date(visit.check_in_at).toLocaleString('id-ID', {
                  dateStyle: 'long',
                  timeStyle: 'short'
                }) %>
              </dd>

              <dt class="col-sm-5 text-muted">Status</dt>
              <dd class="col-sm-7">
                <span class="badge bg-success"><%= visit.status %></span>
              </dd>

            </dl>
          </div>
        </div>

      <% } else { %>

        <!-- Fallback jika data tidak tersedia -->
        <div class="alert alert-warning" role="alert">
          Data kunjungan tidak ditemukan.
        </div>

      <% } %>

      <!-- Tombol Kembali ke Form -->
      <div class="d-grid">
        <a href="/" class="btn btn-outline-primary btn-lg">
          &larr; Kembali ke Form Pendaftaran
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
